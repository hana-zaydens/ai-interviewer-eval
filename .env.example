# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# Anthropic API key — required for LLM classifier (default)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API key — alternative if you configure the classifier to use OpenAI models
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Airtable credentials — only needed for the Airtable manual coding workflow
# Create a Personal Access Token at https://airtable.com/create/tokens
# Your Base ID is in the URL when you open your base: airtable.com/appXXXXXXXXXXXXXX
AIRTABLE_PAT=your-airtable-personal-access-token
AIRTABLE_BASE_ID=your-airtable-base-id
